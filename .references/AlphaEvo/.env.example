# AlphaEvo — Environment Configuration
# Copy to .env and fill in your values

# ── LLM Configuration ────────────────────────────────────────────────
# Required for: alphaevo strategy create, alphaevo evolve
# Not needed for: alphaevo run, alphaevo leaderboard (pure backtest)
ALPHAEVO_API_KEY=your_api_key_here
ALPHAEVO_LLM_MODEL=gemini/gemini-2.0-flash
# ALPHAEVO_LLM_REFLECT_MODEL=deepseek/deepseek-chat

# ── Data Source ──────────────────────────────────────────────────────
# Default data adapter: yfinance / akshare / dsa
ALPHAEVO_DATA_ADAPTER=yfinance

# For daily_stock_analysis integration (dsa adapter only)
# ALPHAEVO_DSA_PATH=/path/to/daily_stock_analysis

# Optional Adanos Market Sentiment context for US equities.
# When set with the yfinance adapter, AlphaEvo can use provider-backed
# news_sentiment_score / negative_news_score instead of only event proxies.
# ADANOS_API_KEY=your_adanos_api_key_here
# ADANOS_API_BASE_URL=https://api.adanos.org

# For tushare (optional)
# TUSHARE_TOKEN=

# ── Paths (optional, defaults to ~/.alphaevo/) ──────────────────────
# ALPHAEVO_DB_PATH=~/.alphaevo/alphaevo.db
# ALPHAEVO_CACHE_DIR=~/.alphaevo/cache/
