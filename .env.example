# ============================================================
# 白泽 (Baize) — 环境变量配置模板
# 复制此文件为 .env 并填入实际的 API 密钥
#   cp .env.example .env
# ============================================================

# --- 妙想金融 API (数据聚合/模拟交易/社区发帖) ---
# 获取地址: https://miaoxiang.dfcfs.com
MX_APIKEY=
MX_API_URL=https://mkapi2.dfcfs.com/finskillshub

# --- 国信证券 API ---
GS_API_KEY=

# --- 华泰证券 API ---
HT_APIKEY=

# --- AI 模型密钥 (可选 — 用于 AI 分析/辩论/质量检查) ---
# 至少配置一个
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- 日志级别 ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- 数据源偏好 ---
# 实时行情优先级 (逗号分隔): mootdx,tencent,guosen,akshare
# 留空使用默认: mootdx,tencent,guosen,akshare
DATA_SOURCE_PRIORITY_REALTIME=

# 财务数据优先级: mootdx,guosen,akshare
DATA_SOURCE_PRIORITY_FUNDAMENTALS=

# 历史 K 线优先级: mootdx,akshare
DATA_SOURCE_PRIORITY_KLINE=

# --- 缓存配置 ---
# 日线 K 线缓存 TTL (秒) — 默认 21600 (6 小时)
CACHE_TTL_DAILY=21600
# 分钟 K 线缓存 TTL (秒) — 默认 1800 (30 分钟)
CACHE_TTL_MINUTE=1800
# Tick 缓存 TTL (秒) — 默认 300 (5 分钟)
CACHE_TTL_TICK=300

# --- 回测配置 ---
# 默认初始资金
BACKTEST_INITIAL_CASH=1000000
# 默认回测起始日期 YYYYMMDD
BACKTEST_START_DATE=20200101
# 默认回测结束日期 YYYYMMDD
BACKTEST_END_DATE=20251231
